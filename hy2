#!/bin/bash

CONFIG="/etc/hysteria/config.yaml"
CLIENTS_FILE="/etc/hysteria/clients.json"
CERT="/etc/hysteria/server.crt"

if [ "$EUID" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

# ─── Вспомогательные функции ───────────────────────────────────────

get_server_ip() {
    curl -s -4 ifconfig.me 2>/dev/null | tr -d '[:space:]'
}

get_port() {
    grep '^listen:' "$CONFIG" | sed 's/listen: ://' | tr -d '[:space:]'
}

get_sni() {
    grep 'url: https://' "$CONFIG" | sed 's/.*url: https:\/\///' | tr -d '[:space:]'
}

get_fingerprint() {
    openssl x509 -in "$CERT" -fingerprint -sha256 -noout 2>/dev/null \
        | cut -d= -f2 \
        | tr -d ':'
}

update_config() {
    python3 -c "
import json, re
with open('$CLIENTS_FILE') as f:
    clients = json.load(f)
with open('$CONFIG') as f:
    content = f.read()
content = re.sub(r'auth:.*', '', content, flags=re.DOTALL).strip()
userpass = '\n'.join('    ' + k + ': ' + v for k, v in clients.items())
auth_block = '\n\nauth:\n  type: userpass\n  userpass:\n' + userpass + '\n'
with open('$CONFIG', 'w') as f:
    f.write(content + auth_block)
"
}

restart_hysteria() {
    systemctl restart hysteria-server > /dev/null 2>&1
    sleep 1
    if [ "$(systemctl is-active hysteria-server)" != "active" ]; then
        echo "  Ошибка: hysteria-server не запустился"
        echo "  Проверь: sudo systemctl status hysteria-server"
        return 1
    fi
    return 0
}

print_links() {
    local NAME="$1"
    local PASS="$2"
    local SERVER_IP="$3"
    local PORT="$4"
    local SNI="$5"
    local FP="$6"
    echo "  Стандартная ссылка:"
    echo "  hy2://${NAME}:${PASS}@${SERVER_IP}:${PORT}?insecure=1&sni=${SNI}#${NAME}"
    echo ""
    echo "  iOS (Happ Plus / pinSHA256):"
    echo "  hy2://${NAME}:${PASS}@${SERVER_IP}:${PORT}?pinSHA256=${FP}&sni=${SNI}#${NAME} (iOS)"
}

regen_cert() {
    local SNI="$1"
    openssl req -x509 -nodes -newkey ec -pkeyopt ec_paramgen_curve:P-256 \
        -keyout /etc/hysteria/server.key \
        -out "$CERT" \
        -subj "/CN=${SNI}" -days 3650 2>/dev/null
    chown hysteria:hysteria /etc/hysteria/server.key "$CERT"
    chmod 640 /etc/hysteria/server.key "$CERT"
}

# ─── Установка / Обновление ────────────────────────────────────────

do_install() {
    echo ""

    # Если уже установлена — обновляем
    if command -v hysteria &>/dev/null && [ -f "$CONFIG" ]; then
        echo "  Обновление Hysteria2"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        CURRENT=$(hysteria version 2>/dev/null | grep -oP 'v\d+\.\d+\.\d+' | head -1)
        echo "  Текущая версия: $CURRENT"
        echo "  Обновляю..."
        bash <(curl -fsSL https://get.hy2.sh/) > /dev/null 2>&1
        NEW=$(hysteria version 2>/dev/null | grep -oP 'v\d+\.\d+\.\d+' | head -1)
        if [ "$CURRENT" = "$NEW" ]; then
            echo "  [✓] Версия актуальна ($NEW)"
        else
            echo "  [✓] Обновлено: $CURRENT → $NEW"
            restart_hysteria
        fi
        show_help
        return
    fi

    # Свежая установка
    echo "  Установка Hysteria2"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    bash <(curl -fsSL https://get.hy2.sh/) > /dev/null 2>&1
    if [ $? -ne 0 ]; then
        echo "  Ошибка установки hysteria2"
        exit 1
    fi
    echo "  [✓] Hysteria2 установлена"

    # Порт
    DEFAULT_PORT=$((RANDOM + 10000))
    echo ""
    read -p "  Порт [$DEFAULT_PORT]: " INPUT_PORT
    PORT=${INPUT_PORT:-$DEFAULT_PORT}

    # SNI
    echo ""
    echo "  Выберите SNI домен:"
    echo "    1. www.nvidia.com"
    echo "    2. www.apple.com"
    echo "    3. www.amazon.com"
    echo "    4. www.cloudflare.com"
    echo "    5. www.samsung.com"
    echo "    6. Ввести свой"
    echo ""
    read -p "  Выбор [1]: " SNI_CHOICE
    SNI_CHOICE=${SNI_CHOICE:-1}
    case "$SNI_CHOICE" in
        1) SNI="www.nvidia.com" ;;
        2) SNI="www.apple.com" ;;
        3) SNI="www.amazon.com" ;;
        4) SNI="www.cloudflare.com" ;;
        5) SNI="www.samsung.com" ;;
        6) read -p "  Введите домен: " SNI ;;
        *) SNI="www.nvidia.com" ;;
    esac
    echo "  [✓] SNI: $SNI"

    # Сертификат
    regen_cert "$SNI"
    echo "  [✓] Сертификат сгенерирован"

    # Первый клиент
    echo ""
    echo "  Hysteria2 требует минимум одного клиента для запуска."
    read -p "  Имя первого клиента [admin]: " FIRST_CLIENT
    FIRST_CLIENT=${FIRST_CLIENT:-admin}
    FIRST_PASS=$(openssl rand -hex 16)

    python3 -c "
import json
data = {'$FIRST_CLIENT': '$FIRST_PASS'}
with open('$CLIENTS_FILE', 'w') as f:
    json.dump(data, f, indent=2)
"

    cat > "$CONFIG" << CONF
listen: :${PORT}

tls:
  cert: /etc/hysteria/server.crt
  key: /etc/hysteria/server.key

masquerade:
  type: proxy
  proxy:
    url: https://${SNI}
    rewriteHost: true

auth:
  type: userpass
  userpass:
    ${FIRST_CLIENT}: ${FIRST_PASS}
CONF

    echo "  [✓] Конфиг записан (порт: $PORT)"

    systemctl enable hysteria-server > /dev/null 2>&1
    systemctl start hysteria-server > /dev/null 2>&1
    sleep 1

    if [ "$(systemctl is-active hysteria-server)" = "active" ]; then
        echo "  [✓] Hysteria2 запущена"
    else
        echo "  [✗] Ошибка запуска. Проверь: sudo systemctl status hysteria-server"
        exit 1
    fi

    SERVER_IP=$(get_server_ip)
    FP=$(get_fingerprint)

    echo ""
    echo "  Первый клиент: $FIRST_CLIENT"
    echo ""
    print_links "$FIRST_CLIENT" "$FIRST_PASS" "$SERVER_IP" "$PORT" "$SNI" "$FP"
    echo ""
    echo "  Установка завершена!"
    show_help
}

# ─── Добавить клиента ───────────────────────────────────────────────

do_add() {
    SERVER_IP=$(get_server_ip)
    PORT=$(get_port)
    SNI=$(get_sni)
    FP=$(get_fingerprint)

    if [ ! -f "$CLIENTS_FILE" ]; then
        echo "{}" > "$CLIENTS_FILE"
    fi

    echo ""
    read -p "  Имя клиента: " CLIENT_NAME

    if [ -z "$CLIENT_NAME" ]; then
        echo "  Ошибка: имя не может быть пустым"
        exit 1
    fi

    EXISTING=$(python3 -c "
import json, sys
with open('$CLIENTS_FILE') as f:
    d = json.load(f)
print(d.get(sys.argv[1], ''))
" "$CLIENT_NAME" 2>/dev/null)

    if [ -n "$EXISTING" ]; then
        echo ""
        echo "  Клиент '$CLIENT_NAME' уже существует"
        echo ""
        print_links "$CLIENT_NAME" "$EXISTING" "$SERVER_IP" "$PORT" "$SNI" "$FP"
        exit 0
    fi

    PASSWORD=$(openssl rand -hex 16)

    python3 -c "
import json, sys
with open('$CLIENTS_FILE') as f:
    data = json.load(f)
data[sys.argv[1]] = sys.argv[2]
with open('$CLIENTS_FILE', 'w') as f:
    json.dump(data, f, indent=2)
" "$CLIENT_NAME" "$PASSWORD"

    update_config
    restart_hysteria || exit 1

    echo ""
    echo "  Клиент '$CLIENT_NAME' добавлен"
    echo ""
    print_links "$CLIENT_NAME" "$PASSWORD" "$SERVER_IP" "$PORT" "$SNI" "$FP"
}

# ─── Список клиентов ────────────────────────────────────────────────

do_list() {
    SERVER_IP=$(get_server_ip)
    PORT=$(get_port)
    SNI=$(get_sni)
    FP=$(get_fingerprint)

    if [ ! -f "$CLIENTS_FILE" ]; then
        echo "  Клиентов нет. Добавьте: hy2 add"
        exit 0
    fi

    COUNT=$(python3 -c "import json; print(len(json.load(open('$CLIENTS_FILE'))))")

    if [ "$COUNT" -eq 0 ]; then
        echo "  Клиентов нет. Добавьте: hy2 add"
        exit 0
    fi

    echo ""
    echo "  Клиенты Hysteria2 (всего: $COUNT)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    python3 -c "
import json, sys
server_ip, server_port, sni, fp = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
with open('$CLIENTS_FILE') as f:
    clients = json.load(f)
for name, password in clients.items():
    std = 'hy2://' + name + ':' + password + '@' + server_ip + ':' + server_port + '?insecure=1&sni=' + sni + '#' + name
    ios = 'hy2://' + name + ':' + password + '@' + server_ip + ':' + server_port + '?pinSHA256=' + fp + '&sni=' + sni + '#' + name + ' (iOS)'
    print()
    print('  ' + name)
    print('  Стандартная : ' + std)
    print('  iOS         : ' + ios)
" "$SERVER_IP" "$PORT" "$SNI" "$FP"
    echo ""
}

# ─── Удалить клиента ────────────────────────────────────────────────

do_delete() {
    if [ ! -f "$CLIENTS_FILE" ]; then
        echo "  Клиентов нет."
        exit 0
    fi

    COUNT=$(python3 -c "import json; print(len(json.load(open('$CLIENTS_FILE'))))")
    if [ "$COUNT" -le 1 ]; then
        echo "  Нельзя удалить последнего клиента — Hysteria2 требует минимум одного."
        echo "  Сначала добавьте нового: hy2 add"
        exit 1
    fi

    echo ""
    read -p "  Имя клиента для удаления: " CLIENT_NAME

    if [ -z "$CLIENT_NAME" ]; then
        echo "  Ошибка: имя не может быть пустым"
        exit 1
    fi

    RESULT=$(python3 -c "
import json, sys
with open('$CLIENTS_FILE') as f:
    data = json.load(f)
name = sys.argv[1]
if name not in data:
    print('NOT_FOUND')
else:
    del data[name]
    with open('$CLIENTS_FILE', 'w') as f:
        json.dump(data, f, indent=2)
    print('DELETED')
" "$CLIENT_NAME")

    if [ "$RESULT" = "NOT_FOUND" ]; then
        echo "  Клиент '$CLIENT_NAME' не найден"
        exit 1
    fi

    update_config
    restart_hysteria || exit 1

    echo "  Клиент '$CLIENT_NAME' удалён"
}

# ─── Смена SNI ──────────────────────────────────────────────────────

do_sni() {
    CURRENT_SNI=$(get_sni)
    echo ""
    echo "  Текущий SNI: $CURRENT_SNI"
    echo ""
    echo "  Выберите новый SNI домен:"
    echo "    1. www.nvidia.com"
    echo "    2. www.apple.com"
    echo "    3. www.amazon.com"
    echo "    4. www.cloudflare.com"
    echo "    5. www.samsung.com"
    echo "    6. Ввести свой"
    echo ""
    read -p "  Выбор [1]: " SNI_CHOICE
    SNI_CHOICE=${SNI_CHOICE:-1}
    case "$SNI_CHOICE" in
        1) NEW_SNI="www.nvidia.com" ;;
        2) NEW_SNI="www.apple.com" ;;
        3) NEW_SNI="www.amazon.com" ;;
        4) NEW_SNI="www.cloudflare.com" ;;
        5) NEW_SNI="www.samsung.com" ;;
        6) read -p "  Введите домен: " NEW_SNI ;;
        *) NEW_SNI="www.nvidia.com" ;;
    esac

    if [ "$NEW_SNI" = "$CURRENT_SNI" ]; then
        echo "  SNI не изменился ($CURRENT_SNI)"
        exit 0
    fi

    # Меняем SNI в конфиге
    python3 -c "
import sys
new_sni = sys.argv[1]
with open('$CONFIG') as f:
    content = f.read()
import re
content = re.sub(r'url: https://[^\s]+', 'url: https://' + new_sni, content)
with open('$CONFIG', 'w') as f:
    f.write(content)
" "$NEW_SNI"

    # Перегенерируем сертификат
    regen_cert "$NEW_SNI"
    echo "  [✓] Сертификат перегенерирован"

    restart_hysteria || exit 1

    echo "  [✓] SNI обновлён: $CURRENT_SNI → $NEW_SNI"
    echo ""
    echo "  Внимание: iOS-ссылки (pinSHA256) изменились — обновите их у клиентов."
    echo "  Запустите: hy2 list"
}

# ─── Статус ─────────────────────────────────────────────────────────

do_status() {
    STATUS=$(systemctl is-active hysteria-server)
    PORT=$(get_port)
    SNI=$(get_sni)
    COUNT=$(python3 -c "import json; print(len(json.load(open('$CLIENTS_FILE'))))" 2>/dev/null || echo 0)
    UPTIME=$(systemctl show hysteria-server --property=ActiveEnterTimestamp | cut -d= -f2)
    echo ""
    echo "  Hysteria2 статус : $STATUS"
    echo "  Порт             : $PORT/UDP"
    echo "  SNI              : $SNI"
    echo "  Клиентов         : $COUNT"
    [ "$STATUS" = "active" ] && echo "  Запущен с        : $UPTIME"
    echo ""
}

# ─── Справка ────────────────────────────────────────────────────────

show_help() {
    echo ""
    echo "  Доступные команды:"
    echo ""
    echo "    hy2 add       — добавить клиента"
    echo "    hy2 list      — список клиентов и ссылки"
    echo "    hy2 del       — удалить клиента"
    echo "    hy2 status    — статус сервера"
    echo "    hy2 sni       — сменить SNI домен"
    echo "    hy2 update    — обновить Hysteria2"
    echo ""
}

# ─── Точка входа ────────────────────────────────────────────────────

if ! command -v hysteria &>/dev/null || [ ! -f "$CONFIG" ]; then
    do_install
    exit 0
fi

case "${1:-}" in
    add)    do_add ;;
    list)   do_list ;;
    del)    do_delete ;;
    status) do_status ;;
    sni)    do_sni ;;
    update) do_install ;;
    *)      show_help ;;
esac
